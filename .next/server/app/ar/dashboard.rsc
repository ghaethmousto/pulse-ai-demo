م","status":{"done":"مكتمل","inProgress":"قيد التنفيذ","delayed":"متأخر","atRisk":"ضمن الخطر","upcoming":"قادم"}}},"sidebar":{"activeProject":"المشروع","projectMeta":"AED 185M · 28 شهراً","userName":"غيث مصطو","userInitials":"غم","userRole":"الإدارة","role":"بوابة المالك","sections":{"workspace":"مساحة العمل","monitor":"المتابعة","system":"النظام","control":"التحكم","projectData":"بيانات المشروع","intelligence":"الذكاء","business":"الأعمال"}},"pulseAssistant":{"name":"Pulse AI","label":"مساعد ذكاء اصطناعي عائم","liveContext":"ذكاء مباشر","placeholder":"اسأل عن هذا المشروع…","open":"فتح Pulse","close":"إغلاق Pulse","suggested":"إجراءات مقترحة","currentSituation":"الوضع الحالي","voice":"الإدخال الصوتي","greeting":"تأخير الجدول 18 يوماً. حزمة الجهات بتاريخ 08-05-2026. تنسيق الخدمات في البوديوم غير محسوم؛ ينتظر قرار العميل بشأن طابق الخدمات. نوصي بتجميد النواة الرأسية هذا الأسبوع.","fallback":"يمكنني الإجابة عن ذلك في النسخة المتصلة الكاملة. في هذا النموذج أعرض حالياً صحة المشروع والتأخيرات والاعتمادات والتقارير والمخاطر والإجراءات المقترحة لمشروع برج الريم."},"skeleton":{"nav":{"product":"المنتج","solutions":"الحلول","resources":"الموارد","customers":"العملاء","platform":"المنصة","addProject":"إضافة مشروع","signIn":"تسجيل الدخول","requestDemo":"احجز عرضاً","intelligence":"ذكاء المشاريع"},"addProject":{"skipSetup":"تخطي الإعداد","back":"رجوع","next":"التالي","stepOf":"الخطوة {n} من {total}","stepLabels":{"role":"الدور","projectInvites":"المشروع والدعوات","connectTools":"ربط الأدوات","pulseReads":"قراءة Pulse","firstBriefing":"الإيجاز الأول"},"stepTitles":{"role":"أهلاً بك. لنربط مشروعك.","projectInvites":"سمِّ مشروعك وادعُ أطرافه.","connectTools":"اربط أدواتك ومستنداتك.","pulseReads":"يقرأ Pulse مشروعك الآن.","firstBriefing":"أنت جاهز. هذا إيجازك الأول."},"goToDashboard":"الانتقال إلى لوحة التحكم","role":{"primaryQuestion":"أنا في الأساس…","selected":"مُختار","or":"أو","invitedQ":"هل تمت دعوتك إلى مشروع؟","invitedBody":"تخطَّ الإعداد. افتح رابط الدعوة أو ألصق رمز المشرو