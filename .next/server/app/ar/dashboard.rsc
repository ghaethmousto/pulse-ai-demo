 الحرجة في رسائل البريد ومحاضر الاجتماعات. ولحظة ظهور المخاطرة تكون قد تحوّلت إلى أزمة.","card3Title":"إعادة عمل مكلفة","card3Body":"يتراكم اختلال التوافق يومياً. ولحظة ظهوره يصبح فرق الميزانية وفقدان الجدول غير قابلَين للاستدراك.","wireframe":{"owner":"OWNER","consultant":"CONSULTANT","contractor":"CONTRACTOR"}},"rolePerspectives":{"eyebrow":"لكل دور في المشروع","title1":"ثلاث زوايا.","title2":"واقع واحد.","subtitle":"كل طرف يرى ما يحتاجه بالضبط — لا ضوضاء ولا سياق مفقود. كل ذلك من حقيقة مشروع واحدة موحدة.","owner":{"title":"المالك","label":"تحكم تنفيذي","bullets":["لوحات تنفيذية","رؤية الميزانية والجدول","تقارير جاهزة لمجلس الإدارة","متابعة القرارات"],"cta":"ادخل بوابة المالك","dashboard":{"label":"برج الريم · عرض المالك","live":"مباشر","spent":"مصروف","budget":"الميزانية","schedule":"الجدول","rfis":"طلبات معلومات مفتوحة","onTrack":"ضمن المسار","variance":"انحراف","pending":"بالانتظار","generateReport":"إنشاء تقرير المجلس","pendingCount":"6 بالانتظار"}},"consultant":{"title":"الاستشاري","label":"مراجعة وامتثال","bullets":["طلبات المعلومات والاعتمادات","مراجعة متعددة التخصصات","الامتثال وضمان الجودة","تنسيق التصميم"],"cta":"ادخل بوابة الاستشاري","dashboard":{"label":"متعقّب طلبات المعلومات · الاستشاري","reviewedCount":"14/18 مراجَعة","items":[{"id":"RFI-124","title":"إيضاح حافة البلاطة","status":"مفتوح"},{"id":"RFI-121","title":"تفصيل تثبيت لوح الواجهة","status":"مراجَع"},{"id":"RFI-118","title":"خلوص شفت الخدمات","status":"مغلق"},{"id":"RFI-115","title":"وضعية مخمّد الحريق","status":"مفتوح"}]}},"contractor":{"title":"المقاول","label":"تنفيذ وتسليم","bullets":["تنفيذ المهام اليومية","تحديثات ميدانية","العوائق والتبعيات","متابعة التسليم"],"cta":"ادخل بوابة المقاول","dashboard":{"label":"مهام اليوم · الأسبوع 34","fieldLog":"السجل الميداني","items":[{"label":"صبّ خرساني — الطابق 14"},{"label":"تمديدات الخدمات — الأسبوع 34"},{"label":"ألواح الواجهة — الجناح الشرقي"},{"label":"الحماية من الحريق — ط 12-14"}]}}},"trustedLogos":{"label":"موثوق به لدى المطورين في الإمارات"}