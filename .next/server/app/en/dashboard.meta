{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/[locale]/layout,_N_T_/[locale]/(app)/layout,_N_T_/[locale]/(app)/dashboard/layout,_N_T_/[locale]/(app)/dashboard/page,_N_T_/en/dashboard"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/$d$locale/!KGFwcCk/dashboard/__PAGE__",
    "/$d$locale/!KGFwcCk/dashboard",
    "/$d$locale/!KGFwcCk",
    "/$d$locale",
    "/_index",
    "/_head"
  ]
}