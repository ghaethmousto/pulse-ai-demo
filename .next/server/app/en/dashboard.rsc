":"on track"},{"label":"Schedule","value":"+2d","unit":"variance"},{"label":"RFIs","value":"12","unit":"open"},{"label":"Risks","value":"4","unit":"high"}],"feedHeader":"One reconciled view · Streaming","feed":[{"tag":"RFI · OPEN","title":"RFI-124 — slab edge detail clarification","meta":"blocks 2 tasks · L4 east"},{"tag":"SUBMITTAL · APPROVED","title":"SB-88 cladding panels approved","meta":"procurement unblocked"},{"tag":"SCHEDULE","title":"MEP rough-in wk-34 delayed +3d","meta":"3 mitigations proposed"},{"tag":"RISK · WEATHER","title":"Wk-34 storm — pour at risk","meta":"crane ops escalated +6h"},{"tag":"DECISION · APPROVED","title":"Façade vendor switch — Owner sign-off","meta":"6 docs linked · audit trail"}],"intelligenceLabel":"Pulse Intelligence","aiNotes":["RFI-124 blocks 3 downstream tasks on L4 east. Recommend escalation to Owner by EOD.","Submittal SB-88 approved — procurement team should initiate PO immediately.","Weather risk wk-34: 68% chance of pour delay. 2 rescheduling options modelled."],"askPulse":"Ask Pulse AI","askPulseExample":"What risks could delay wk-34 handover?","sidebarItems":["Overview","Documents","Decisions","Tasks","Risks","Submittals","Timeline","Intelligence"]},"integrations":{"eyebrow":"Integrations","titleLead":"Works with the tools","titleAccent":"already on site.","subtitle":"Pulse connects to your existing stack — no rip-and-replace, no retraining. Just intelligence on top of what you already use.","andMore":"+ REST API and webhooks for custom integrations","categories":{"projectMgmt":"Project Mgmt","documentControl":"Document Control","bimDesign":"BIM & Design","finance":"Finance","scheduling":"Scheduling","bim":"BIM","documents":"Documents","markup":"Markup","communication":"Communication","reporting":"Reporting","email":"Email"}},"proof":{"eyebrow":"Proof","titleLead":"Teams ship projects","titleAccent":"on Pulse.","subtitle":"From land acquisition to handover — construction's most demanding teams trust Pulse to keep every stakeholder aligned.","swipeHint":"Swipe to see more stories","comingSoon":"Coming Soon","prev":"Previous","next":"Next","cards":{"ora":{"tag":"ORA Developers","description":"Bayn represents development at a scale where land, approvals, consultants, and delivery teams must operate as one. <b>Pulse</b> turns that complexity into a coordinated development system.","cta":"View the Bayn development scenario"},"vision":{"tag":"Pulse Vision","description":"<b>Pulse Vision</b> transforms site cameras into live construction intelligence — reading progress, activity, safety signals, and field conditions directly into the project graph.","cta":"Get early access to Pulse Vision"},"aldar":{"tag":"Aldar","description":"Capital projects lose value when decisions fragment and rework appears too late. <b>Pulse</b> keeps the project record verified, the teams aligned, and the risk visible early.","cta":"View the capital control scenario"},"emaar":{"tag":"Emaar Group","description":"Portfolio-scale delivery requires more than dashboards. <b>Pulse</b> gives leadership a live view of decisions, risks, dependencies, and delays before they become costly.","cta":"Explore the portfolio command scenario"}}},"finalCta":{"badge":"Now Available · UAE & GCC","h1Line1":"Built for the future.","h1Line2":"Available today.","body":"Give your project team the intelligence layer they deserve. One truth. Every role. Real time.","primary":"Get started","secondary":"Contact an expert","tagline":"Designed and built for the future of construction intelligence.","imprint":"Pulse AI · UAE · 2026"},"footer":{"platform":"Platform","resources":"Resources","company":"Company","contact":"Contact","tagline":"The operational truth layer for construction. Connecting Owners, Consultants, and Contractors around a single reliable reality.","rights":"© 2026 Pulse AI. All rights reserved.","credit":"Designed and Built By: Ghaeth M Mousto","platformLinks":["Overview","Owner","Consultant","Contractor"],"resourcesLinks":["Docs","Changelog","Case studies","Security"],"companyLinks":["About","Careers","Press","Legal"],"office":"Dubai · Abu Dhabi · Riyadh"},"solutions":{"eyebrow":"Solutions by role","h1":"Pick your job. We've already mapped the work.","subtitle":"The same source, three different jobs. Pick the one that wakes you up at 2am.","ctaBookDemo":"Book demo","whyEyebrow":"Why it matters","whyTitle":"Three lenses on the same project.","chips":["01 Owner","02 Consultant","03 Contractor"],"outcomes":[{"label":"Owner outcome","value":"12hrs","caption":"reporting prep saved monthly"},{"label":"Consultant outcome","value":"-71%","caption":"median RFI turnaround"},{"label":"Contractor outcome","value":"+19d","caption":"avg. early warning lead time"}],"sections":[{"tag":"01 — Owner","title":"Hand the board a defensible report in 5 minutes.","body":"Pulse turns a project of scattered signals into an executive brief — status, risk, cashflow, and decisions with source trails.","cta":"Read the owner playbook","visualTitle":"Monday brief · 03","chips":["Decision ledger","Portfolio KPIs","Risk radar","Ask Pulse"]},{"tag":"02 — Consultant","title":"Cut RFI cycle from 14 days to 4.","body":"Pulse drafts the response map, finds precedent, routes for sign-off, and tracks SLA risk by discipline.","cta":"Read the consultant playbook","visualTitle":"RFI cycle · last 30 days","chips":["RFI dashboard","Document graph","Submittal intelligence"]},{"tag":"03 — Contractor","title":"See the slip three weeks before it happens.","body":"Pulse reconciles material procurement with daily field reports, weather, deliveries, and crew availability.","cta":"Read the contractor playbook","visualTitle":"Tower B · pour 4–7","chips":["Schedule intelligence","Daily report","Mobile field app"]}],"liveView":"Live view","previewLabel":"[ project signal preview ]","lensesShort":["Owner sees defensible status.","Consultant sees review flow.","Contractor sees blockers and crews."]},"resources":{"eyebrow":"The platform","h1":"E